# Django Settings
# IMPORTANT: Generate a unique SECRET_KEY for production:
# python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-here-change-in-production

# Set to False in production
DEBUG=True

ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# Development: SQLite (default below)
# Production: Set DB_ENGINE to django.db.backends.postgresql and fill in details
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
# For PostgreSQL uncomment below:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=remedium_hms
# DB_USER=postgres
# DB_PASSWORD=your_secure_password_here
# DB_HOST=localhost
# DB_PORT=5432

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For production, use SendGrid or Gmail SMTP:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@remediumhms.com

# Security Settings
# Development: all False below
# Production: Set to True with HTTPS
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000

# Application Settings
TIMEZONE=UTC
LANGUAGE_CODE=en-us
